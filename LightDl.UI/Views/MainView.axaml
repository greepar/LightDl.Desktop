<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LightDl.UI.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="390"
             d:DesignHeight="844"
             x:Class="LightDl.UI.Views.MainView"
             x:DataType="vm:MainViewModel">
  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <UserControl.Styles>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="#18FFFFFF" />
      <Setter Property="BorderBrush" Value="#24FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
    </Style>
    <Style Selector="ToggleButton.nav">
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="Margin" Value="0,2" />
    </Style>
    <Style Selector="ToggleButton.nav:checked">
      <Setter Property="Background" Value="#2874E8" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#2874E8" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Opacity" Value="0.62" />
    </Style>
    <Style Selector="Border.mobile-card">
      <Setter Property="Background" Value="#151A23" />
      <Setter Property="BorderBrush" Value="#252C38" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="20" />
    </Style>
    <Style Selector="Border.mobile-chip">
      <Setter Property="Background" Value="#1B2230" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="10,6" />
    </Style>
    <Style Selector="Button.mobile-primary">
      <Setter Property="Background" Value="#5B8CFF" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="18,12" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.mobile-quiet">
      <Setter Property="Background" Value="#1B2230" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="12,8" />
    </Style>
    <Style Selector="TextBlock.mobile-muted">
      <Setter Property="Foreground" Value="#94A3B8" />
    </Style>
  </UserControl.Styles>

  <Panel>
    <Grid ColumnDefinitions="Auto,*" IsVisible="{Binding IsDesktopLayout}">
      <Border Width="220" Padding="14" Margin="12" Classes="card">
        <Grid RowDefinitions="Auto,Auto,*,Auto">
          <StackPanel Spacing="2" Margin="6,4,6,20">
            <TextBlock Text="LightDl" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="Download Manager" Classes="muted" />
          </StackPanel>

          <StackPanel Grid.Row="1" Spacing="2">
            <ToggleButton Content="全部任务" Classes="nav" IsChecked="{Binding IsAllSelected, Mode=OneWay}" Command="{Binding SelectSectionCommand}" CommandParameter="all" />
            <ToggleButton Content="正在下载" Classes="nav" IsChecked="{Binding IsDownloadingSelected, Mode=OneWay}" Command="{Binding SelectSectionCommand}" CommandParameter="downloading" />
            <ToggleButton Content="已完成" Classes="nav" IsChecked="{Binding IsCompletedSelected, Mode=OneWay}" Command="{Binding SelectSectionCommand}" CommandParameter="completed" />
            <ToggleButton Content="下载失败" Classes="nav" IsChecked="{Binding IsFailedSelected, Mode=OneWay}" Command="{Binding SelectSectionCommand}" CommandParameter="failed" />
          </StackPanel>

          <StackPanel Grid.Row="3" Spacing="2">
            <ToggleButton Content="浏览器集成" Classes="nav" IsChecked="{Binding IsBrowserSelected, Mode=OneWay}" Command="{Binding SelectSectionCommand}" CommandParameter="browser" />
            <ToggleButton Content="设置" Classes="nav" IsChecked="{Binding IsSettingsSelected, Mode=OneWay}" Command="{Binding SelectSectionCommand}" CommandParameter="settings" />
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" Margin="12,12,16,12">
        <Grid ColumnDefinitions="*,Auto" Margin="4,2,4,14" IsVisible="{Binding IsDownloadsPage}">
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <Button Content="+ 新建任务"
                    Click="OpenNewDownloadDialog"
                    Padding="18,10" />
            <Button Content="全部暂停"
                    Command="{Binding PauseAllCommand}"
                    Padding="18,10" />
          </StackPanel>
        </Grid>

        <Grid ColumnDefinitions="*,Auto" Margin="4,2,4,14" IsVisible="{Binding IsSettingsPage}">
          <StackPanel>
            <TextBlock Text="{Binding PageTitle}" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="{Binding PageSubtitle}" Classes="muted" />
          </StackPanel>
        </Grid>

        <Grid ColumnDefinitions="*,Auto" Margin="4,2,4,14" IsVisible="{Binding IsBrowserIntegrationPage}">
          <StackPanel>
            <TextBlock Text="{Binding PageTitle}" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="{Binding PageSubtitle}" Classes="muted" />
          </StackPanel>
        </Grid>

        <Grid Grid.Row="1" IsVisible="{Binding IsDownloadsPage}">
          <Panel>
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        IsVisible="{Binding HasNoVisibleDownloads}">
              <TextBlock Text="暂无符合条件的任务" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="添加下载链接，或从左侧切换其他分类" Classes="muted" />
            </StackPanel>
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" IsVisible="{Binding HasVisibleDownloads}">
              <ItemsControl ItemsSource="{Binding VisibleDownloads}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:DownloadItemViewModel">
                    <Border Classes="card" Padding="14" Margin="0,0,0,10">
                      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                        <StackPanel Spacing="2">
                          <TextBlock Text="{Binding FileName}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding SourceUrl}" Classes="muted" FontSize="12" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                          <Button Content="暂停" Command="{Binding PauseCommand}" IsVisible="{Binding IsActive}" />
                          <Button Content="继续" Command="{Binding ResumeCommand}" IsVisible="{Binding CanResume}" />
                          <Button Content="移除" Command="{Binding RemoveCommand}" />
                        </StackPanel>
                        <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Minimum="0" Maximum="100"
                                     Value="{Binding ProgressPercentage}" Height="7" Margin="0,12,0,8" />
                        <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto,Auto,Auto">
                          <TextBlock Text="{Binding StatusText}" />
                          <TextBlock Grid.Column="1" Text="{Binding SizeText}" Classes="muted" Margin="14,0" />
                          <TextBlock Grid.Column="2" Text="{Binding SpeedText}" Classes="muted" Margin="14,0" />
                          <TextBlock Grid.Column="3" Text="{Binding RemainingText}" Classes="muted" Margin="14,0,0,0" />
                        </Grid>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Panel>
        </Grid>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" IsVisible="{Binding IsSettingsPage}">
          <StackPanel Spacing="12">
            <Border Classes="card" Padding="18">
              <StackPanel Spacing="12">
                <TextBlock Text="下载" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="默认保存目录" Classes="muted" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Text="{Binding Settings.DefaultDownloadDirectory}" />
                  <Button Grid.Column="1" Content="选择目录" Click="BrowseDownloadDirectory" Margin="8,0,0,0" />
                </Grid>
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                  <StackPanel Spacing="5">
                    <TextBlock Text="同时下载任务" Classes="muted" />
                    <NumericUpDown Value="{Binding Settings.MaxConcurrentDownloads}" Minimum="1" Maximum="16" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="5">
                    <TextBlock Text="连接数" Classes="muted" />
                    <NumericUpDown Value="{Binding Settings.ChunkCount}" Minimum="1" Maximum="64" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="5">
                    <TextBlock Text="分段大小 (MB)" Classes="muted" />
                    <NumericUpDown Value="{Binding Settings.SegmentSizeMb}" Minimum="1" Maximum="256" />
                  </StackPanel>
                  <StackPanel Grid.Column="3" Spacing="5">
                    <TextBlock Text="全局限速 (KiB/s，0 为不限速)" Classes="muted" />
                    <NumericUpDown Value="{Binding Settings.SpeedLimitKib}" Minimum="0" Maximum="1048576" />
                  </StackPanel>
                </Grid>
                <CheckBox Content="启用动态连接数" IsChecked="{Binding Settings.EnableDynamicConcurrency}" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" IsVisible="{Binding Settings.EnableDynamicConcurrency}">
                  <StackPanel Spacing="5">
                    <TextBlock Text="最小连接数" Classes="muted" />
                    <NumericUpDown Value="{Binding Settings.MinChunkCount}" Minimum="1" Maximum="64" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="5">
                    <TextBlock Text="最大连接数" Classes="muted" />
                    <NumericUpDown Value="{Binding Settings.MaxChunkCount}" Minimum="1" Maximum="64" />
                  </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                  <StackPanel Spacing="5">
                    <TextBlock Text="已有文件处理" Classes="muted" />
                    <ComboBox SelectedIndex="{Binding Settings.FileConflictPolicy}">
                      <ComboBoxItem Content="覆盖" />
                      <ComboBoxItem Content="报错" />
                      <ComboBoxItem Content="跳过" />
                      <ComboBoxItem Content="自动重命名" />
                    </ComboBox>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Bottom">
                    <CheckBox Content="启用断点续传" IsChecked="{Binding Settings.EnableResume}" />
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <Border Classes="card" Padding="18">
              <StackPanel Spacing="12">
                <TextBlock Text="网络" FontSize="18" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                  <StackPanel Spacing="5">
                    <TextBlock Text="请求超时 (秒)" Classes="muted" />
                    <NumericUpDown Value="{Binding Settings.TimeoutSeconds}" Minimum="5" Maximum="600" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="5">
                    <TextBlock Text="重试次数" Classes="muted" />
                    <NumericUpDown Value="{Binding Settings.MaxRetry}" Minimum="0" Maximum="100" />
                  </StackPanel>
                </Grid>
                <TextBlock Text="代理" Classes="muted" />
                <ComboBox SelectedIndex="{Binding Settings.ProxyMode}">
                  <ComboBoxItem Content="使用系统代理" />
                  <ComboBoxItem Content="不使用代理" />
                  <ComboBoxItem Content="自定义代理" />
                </ComboBox>
                <TextBox Text="{Binding Settings.ProxyUrl}"
                         PlaceholderText="http://127.0.0.1:7890"
                         IsVisible="{Binding Settings.UsesCustomProxy}" />
                <TextBlock Text="User-Agent" Classes="muted" />
                <TextBox Text="{Binding Settings.UserAgent}" PlaceholderText="留空使用 LightDl 默认值" />
                <CheckBox Content="忽略 SSL 证书错误（不安全）" IsChecked="{Binding Settings.IgnoreSslErrors}" />
              </StackPanel>
            </Border>

            <Border Classes="card" Padding="18">
              <StackPanel Spacing="12">
                <TextBlock Text="应用" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="主题" Classes="muted" />
                <ComboBox SelectedIndex="{Binding Settings.ThemeMode}">
                  <ComboBoxItem Content="跟随系统" />
                  <ComboBoxItem Content="浅色" />
                  <ComboBoxItem Content="深色" />
                </ComboBox>
                <CheckBox Content="关闭主窗口时最小化到托盘" IsChecked="{Binding Settings.CloseToTray}" />
                <CheckBox Content="下载完成后显示系统通知" IsChecked="{Binding Settings.ShowCompletionNotification}" />
                <CheckBox Content="启用浏览器自动接管" IsChecked="{Binding Settings.EnableBrowserIntegration}" />
                <Button Content="保存设置" Command="{Binding SaveSettingsCommand}" HorizontalAlignment="Right" Padding="24,10" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Classes="card" Padding="24" IsVisible="{Binding IsBrowserIntegrationPage}">
          <StackPanel Spacing="14" MaxWidth="620" HorizontalAlignment="Left" VerticalAlignment="Top">
            <TextBlock Text="自动接管" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="LightDl 将使用 Native Messaging 接收 Chrome、Edge 和 Firefox 创建的下载。捕获下载后会弹出独立下载信息窗口，不会在当前页面内嵌确认表单。" TextWrapping="Wrap" />
            <Border Background="#183A7AFE" CornerRadius="10" Padding="12">
              <TextBlock Text="{Binding BrowserHostStatus}" TextWrapping="Wrap" />
            </Border>
            <CheckBox Content="启用浏览器自动接管" IsChecked="{Binding Settings.EnableBrowserIntegration}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="注册 / 修复宿主" Command="{Binding RegisterBrowserHostCommand}" />
              <Button Content="移除宿主" Command="{Binding UnregisterBrowserHostCommand}" />
              <Button Content="保存设置" Command="{Binding SaveSettingsCommand}" />
            </StackPanel>
            <TextBlock Text="扩展源码位于 browser-extensions/automatic。Chromium 扩展 ID 已固定，可用于 Chrome 和 Edge；Firefox 使用固定扩展 ID。" Classes="muted" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="4,10,4,2">
          <TextBlock Text="{Binding StatusMessage}" Classes="muted" />
          <TextBlock Grid.Column="1" Text="正在下载: " Classes="muted" />
          <TextBlock Grid.Column="1" Text="{Binding ActiveCount}" Margin="58,0,18,0" />
          <TextBlock Grid.Column="2" Text="已完成: " Classes="muted" />
          <TextBlock Grid.Column="2" Text="{Binding CompletedCount}" Margin="50,0,0,0" />
        </Grid>
      </Grid>
    </Grid>

    <Border Background="#0B0E14"
            Padding="18,16,18,14"
            IsVisible="{Binding IsMobileLayout}">
      <Grid RowDefinitions="Auto,Auto,*">
        <Grid ColumnDefinitions="*,Auto" Margin="2,0,2,16">
          <StackPanel Spacing="5">
            <Border Background="#1C2D52"
                    CornerRadius="7"
                    Padding="8,4"
                    HorizontalAlignment="Left">
              <TextBlock Text="LIGHTDL"
                         Foreground="#8FB1FF"
                         FontSize="10"
                         FontWeight="Bold"
                         LetterSpacing="1.4" />
            </Border>
            <TextBlock Text="下载中心" FontSize="27" FontWeight="Bold" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Classes="mobile-chip">
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <TextBlock Text="进行中" Classes="mobile-muted" FontSize="12" />
                  <TextBlock Text="{Binding ActiveCount}" Foreground="#8FB1FF" FontWeight="Bold" />
                </StackPanel>
              </Border>
              <Border Classes="mobile-chip">
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <TextBlock Text="已完成" Classes="mobile-muted" FontSize="12" />
                  <TextBlock Text="{Binding CompletedCount}" Foreground="#67D7A5" FontWeight="Bold" />
                </StackPanel>
              </Border>
            </StackPanel>
          </StackPanel>

          <Button Grid.Column="1"
                  Content="暂停全部"
                  Command="{Binding PauseAllCommand}"
                  Classes="mobile-quiet"
                  VerticalAlignment="Top" />
        </Grid>

        <Border Grid.Row="1" Classes="mobile-card" Padding="16" Margin="0,0,0,14">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="新建下载" FontSize="17" FontWeight="SemiBold" />
                <TextBlock Text="粘贴文件链接即可开始" Classes="mobile-muted" FontSize="12" />
              </StackPanel>
              <Border Grid.Column="1" Classes="mobile-chip" VerticalAlignment="Center">
                <TextBlock Text="HTTP / HTTPS" Foreground="#8FB1FF" FontSize="11" />
              </Border>
            </Grid>

            <TextBox PlaceholderText="https://example.com/file.zip"
                     Text="{Binding NewUrl}"
                     MinHeight="46"
                     FontSize="14" />

            <Grid ColumnDefinitions="*,Auto">
              <StackPanel VerticalAlignment="Center" Spacing="2">
                <TextBlock Text="保存位置" Classes="mobile-muted" FontSize="11" />
                <TextBlock Text="应用下载目录" FontSize="13" />
              </StackPanel>
              <Button Grid.Column="1"
                      Content="开始下载"
                      Command="{Binding AddDownloadCommand}"
                      Classes="mobile-primary" />
            </Grid>
          </StackPanel>
        </Border>

        <Panel Grid.Row="2">
          <StackPanel HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="12"
                      Margin="30"
                      IsVisible="{Binding HasNoDownloads}">
            <Border Width="70"
                    Height="70"
                    Background="#151D2C"
                    BorderBrush="#29416E"
                    BorderThickness="1"
                    CornerRadius="35">
              <TextBlock Text="DL"
                         Foreground="#8FB1FF"
                         FontSize="20"
                         FontWeight="Bold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="还没有下载任务"
                       FontSize="17"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock Text="在上方粘贴链接，任务会显示在这里"
                       Classes="mobile-muted"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#718096"
                       FontSize="12"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
          </StackPanel>

          <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                        IsVisible="{Binding HasDownloads}">
            <ItemsControl ItemsSource="{Binding Downloads}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:DownloadItemViewModel">
                  <Border Classes="mobile-card" Padding="15" Margin="0,0,0,10">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="3">
                          <TextBlock Text="{Binding FileName}"
                                     FontSize="15"
                                     FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Text="{Binding SourceUrl}"
                                     Classes="mobile-muted"
                                     FontSize="11"
                                     TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Border Grid.Column="1" Classes="mobile-chip" Margin="10,0,0,0">
                          <TextBlock Text="{Binding StatusText}" Foreground="#8FB1FF" FontSize="11" />
                        </Border>
                      </Grid>

                      <ProgressBar Grid.Row="1"
                                   Minimum="0"
                                   Maximum="100"
                                   Value="{Binding ProgressPercentage}"
                                   Height="6"
                                   Margin="0,13,0,10" />

                      <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Text="{Binding SizeText}" Classes="mobile-muted" FontSize="11" />
                        <TextBlock Grid.Column="1" Text="{Binding SpeedText}" Foreground="#67D7A5" FontSize="11" Margin="10,0" />
                        <TextBlock Grid.Column="2" Text="{Binding RemainingText}" Classes="mobile-muted" FontSize="11" />
                      </Grid>

                      <StackPanel Grid.Row="3"
                                  Orientation="Horizontal"
                                  HorizontalAlignment="Right"
                                  Spacing="7"
                                  Margin="0,12,0,0">
                        <Button Content="暂停" Command="{Binding PauseCommand}" Classes="mobile-quiet" IsVisible="{Binding IsActive}" />
                        <Button Content="继续" Command="{Binding ResumeCommand}" Classes="mobile-primary" IsVisible="{Binding CanResume}" />
                        <Button Content="移除" Command="{Binding RemoveCommand}" Classes="mobile-quiet" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Panel>
      </Grid>
    </Border>
  </Panel>
</UserControl>
