{
  "manifest_version": 3,
  "name": "LightDl Automatic Integration",
  "version": "0.1.0",
  "description": "Automatically hand browser downloads to LightDl through Native Messaging.",
  "permissions": ["downloads", "cookies", "nativeMessaging"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "automatic-integration@lightdl.io",
      "strict_min_version": "128.0"
    }
  }
}
