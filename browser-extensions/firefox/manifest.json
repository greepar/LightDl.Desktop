{
  "manifest_version": 3,
  "name": "LightDl Integration",
  "version": "0.1.0",
  "description": "Send links and the current page to LightDl.",
  "permissions": ["activeTab", "contextMenus"],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "Download with LightDl"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "integration@lightdl.io",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
