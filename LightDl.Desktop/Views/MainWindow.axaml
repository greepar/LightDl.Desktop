<suki:SukiWindow xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:LightDl.UI.Views"
        xmlns:vm="using:LightDl.UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
         x:Class="LightDl.Desktop.Views.MainWindow"
         x:DataType="vm:MainViewModel"
         Icon="avares://LightDl.UI/Assets/avalonia-logo.ico"
         Title="LightDl"
         Width="1180"
         Height="760"
         MinWidth="860"
         MinHeight="560"
         CanResize="True"
         BackgroundStyle="Gradient">
        <suki:SukiWindow.Hosts>
                <suki:SukiDialogHost Manager="{CompiledBinding DialogManager}" />
        </suki:SukiWindow.Hosts>
        <views:MainView />
</suki:SukiWindow>
